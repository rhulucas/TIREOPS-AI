# ============ Database Strategy ============
# Local development: use Docker PostgreSQL on your machine.
# Shared / staging / production: use a managed PostgreSQL instance such as Azure Database for PostgreSQL.
# Do not point local development at production by default.

# Local Docker PostgreSQL
DATABASE_URL="postgresql://tireops:tireops_dev@localhost:5432/tireops"

# ============ Auth (NextAuth.js) ============
# Generate: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-at-least-32-chars"

# ============ AI (OpenAI) ============
# Optional - AI modules return mock results if not set
# Leave empty during local development if you want mock AI responses
OPENAI_API_KEY=""
