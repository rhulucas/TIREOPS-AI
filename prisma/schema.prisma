generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String?        @map("password_hash")
  name          String?
  role          String         @default("USER")
  emailVerified DateTime?      @map("email_verified")
  image         String?
  accounts         Account[]
  compoundSpecs    CompoundSpec[]
  emailDrafts      EmailDraft[]
  emailThreads     EmailThread[]
  orders           Order[]
  quotes           Quote[]
  sessions         Session[]
  treadDesigns     TreadDesign[]
  requestedChanges ChangeRequest[] @relation("RequestedChanges")
  reviewedChanges  ChangeRequest[] @relation("ReviewedChanges")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  company   String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  invoices  Invoice[]
  orders    Order[]
  quotes    Quote[]
}

model Order {
  id              String    @id @default(cuid())
  orderNumber     String    @map("order_number")
  status          String
  customerName    String?   @map("customer_name")
  tireSpec        String?   @map("tire_spec")
  quantity        Int       @default(0)
  userId          String?   @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  customerId      String?   @map("customer_id")
  dueDate         DateTime? @map("due_date")
  value           Float?
  quoteId         String?   @unique @map("quote_id")
  trackingNumber  String?   @map("tracking_number")
  shippedAt       DateTime? @map("shipped_at")
  deliveredAt     DateTime? @map("delivered_at")
  customer        Customer? @relation(fields: [customerId], references: [id])
  user            User?     @relation(fields: [userId], references: [id])
  quote           Quote?    @relation(fields: [quoteId], references: [id])
  invoice         Invoice?
}

model Quote {
  id           String    @id @default(cuid())
  size         String
  loadIndex    String?   @map("load_index")
  speedRating  String?   @map("speed_rating")
  userId       String?   @map("user_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  category     String?
  compound     String?
  customerId   String?   @map("customer_id")
  customerName String?   @map("customer_name")
  notes        String?
  quantity     Int?
  result       String?
  status       String    @default("DRAFT")
  deliveryDate DateTime? @map("delivery_date")
  customer     Customer? @relation(fields: [customerId], references: [id])
  user         User?     @relation(fields: [userId], references: [id])
  order        Order?
}

model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String    @map("invoice_number")
  customerId      String?   @map("customer_id")
  customerName    String    @map("customer_name")
  customerAddress String    @map("customer_address")
  orderRef        String?   @map("order_ref")
  orderId         String?   @unique @map("order_id")
  items           String
  paymentTerms    String    @default("Net 30") @map("payment_terms")
  taxRate         Float     @default(0) @map("tax_rate")
  preview         String?
  status          String    @default("DRAFT")
  paidAt          DateTime? @map("paid_at")
  userId          String?   @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  customer        Customer? @relation(fields: [customerId], references: [id])
  order           Order?    @relation(fields: [orderId], references: [id])
}

model EmailDraft {
  id          String   @id @default(cuid())
  inquiryType String   @map("inquiry_type")
  emailText   String   @map("email_text")
  tone        String?
  result      String?
  userId      String?  @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [id])
}

model CompoundSpec {
  id              String   @id @default(cuid())
  applicationType String   @map("application_type")
  primaryPolymer  String   @map("primary_polymer")
  fillerSystem    String   @map("filler_system")
  shoreA          String?  @map("shore_a")
  tensileStrength String?  @map("tensile_strength")
  curingSystem    String   @map("curing_system")
  cureTemp        String?  @map("cure_temp")
  notes           String?
  result          String?
  userId          String?  @map("user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User?    @relation(fields: [userId], references: [id])
}

model TreadDesign {
  id               String          @id @default(cuid())
  name             String?
  application      String?
  widthMm          Int?            @map("width_mm")
  heightMm         Int?            @map("height_mm")
  moldSpec         String?         @map("mold_spec")
  userId           String?         @map("user_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  category         String          @default("PCR")
  season           String          @default("ALL_SEASON")
  status           String          @default("ACTIVE")
  version          Int             @default(1)
  grooveDepthMm    Float?          @map("groove_depth_mm")
  noiseRating      String?         @map("noise_rating")
  wetGripRating    String?         @map("wet_grip_rating")
  rollingResistance String?        @map("rolling_resistance")
  notes            String?
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at")
  user             User?           @relation(fields: [userId], references: [id])
  changeRequests   ChangeRequest[] @relation("DesignChangeRequests")
}

model ChangeRequest {
  id              String      @id @default(cuid())
  designId        String      @map("design_id")
  requesterId     String      @map("requester_id")
  type            String
  description     String
  proposedChanges String      @map("proposed_changes")
  status          String      @default("PENDING")
  reviewNote      String?     @map("review_note")
  reviewerId      String?     @map("reviewer_id")
  aiAssessment    String?     @map("ai_assessment")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  design          TreadDesign @relation("DesignChangeRequests", fields: [designId], references: [id], onDelete: Cascade)
  requester       User        @relation("RequestedChanges", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer        User?       @relation("ReviewedChanges", fields: [reviewerId], references: [id], onDelete: SetNull)
}

model ProductionLine {
  id         String @id @default(cuid())
  name       String
  status     String
  efficiency Float  @default(0)
  qcFails    Int    @default(0) @map("qc_fails")
}

model EmailThread {
  id            String         @id @default(cuid())
  subject       String
  customerName  String         @map("customer_name")
  customerEmail String?        @map("customer_email")
  quoteId       String?        @map("quote_id")
  orderId       String?        @map("order_id")
  status        String         @default("OPEN")
  tireSpec      String?        @map("tire_spec")
  quantity      Int?
  unitPrice     Float?         @map("unit_price")
  userId        String?        @map("user_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  messages      EmailMessage[]
  user          User?          @relation(fields: [userId], references: [id])
}

model EmailMessage {
  id        String      @id @default(cuid())
  threadId  String      @map("thread_id")
  sender    String
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  thread    EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}
